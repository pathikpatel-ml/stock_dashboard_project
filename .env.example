# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit secrets.

# Supabase REST API (used by user_store.py)
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Supabase PostgreSQL direct connection (legacy / migrations)
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Flask session signing key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-generate-a-random-hex-string

# Fernet encryption key for Zerodha credentials — generate ONCE with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store this safely — if lost, existing encrypted credentials cannot be decrypted.
MASTER_ENCRYPTION_KEY=your-fernet-key-here

# Gmail SMTP — for Kite token-expired alert emails
# NOTIFY_EMAIL: the Gmail address that sends the alert (can be same as your own Gmail)
# NOTIFY_EMAIL_PASSWORD: Gmail App Password (NOT your regular password)
#   Generate at: myaccount.google.com -> Security -> 2-Step Verification -> App Passwords
#   Select app: Mail, device: Other -> gives a 16-char password
NOTIFY_EMAIL=yourname@gmail.com
NOTIFY_EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# GitHub Actions trigger token — any random string, same value in GitHub Secrets + here
GTT_TRIGGER_TOKEN=your-random-secret-token

# Admin email — this user gets the Admin tab and can approve/reject signups
# Defaults to pathikc129@gmail.com if not set
ADMIN_EMAIL=pathikc129@gmail.com
